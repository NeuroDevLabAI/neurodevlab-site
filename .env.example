# ─────────────────────────────────────────────────────────────
#  NeuroDevLab — site environment. Copy to .env.local for dev,
#  and set these in Vercel → Project → Settings → Environment Variables.
#  Never commit real secrets. NEXT_PUBLIC_* are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────
# Production URL (canonical / hreflang / OG). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://neurodevlab.vercel.app

# Calendly booking link — the single CTA target everywhere.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/neurodevlab-ai/30min

# Public contact email (footer + Resend owner-notification target).
NEXT_PUBLIC_CONTACT_EMAIL=neurodevlab.ai@gmail.com

# ── Availability badge & scarcity — MUST STAY TRUTHFUL ───────
# true  → green "Available for new projects"
# false → "Currently at capacity"
NEXT_PUBLIC_ACCEPTING_CLIENTS=true
NEXT_PUBLIC_CLIENT_SLOTS=3

# Exit-intent popup (desktop, once per session). false disables it.
NEXT_PUBLIC_EXIT_INTENT=true

# ── Live stats — wire to the VPS API later (static defaults now) ──
NEXT_PUBLIC_STAT_MISSIONS=0
NEXT_PUBLIC_STAT_CLIENTS=0
NEXT_PUBLIC_STAT_TECHNOLOGIES=15

# ── Analytics (Plausible, cookieless). Empty = disabled. ─────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Contact form delivery (SERVER-ONLY secrets) ──────────────
# Telegram bot token + the Clients channel id (-5183936269).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CLIENTS_CHAT_ID=-5183936269

# Resend — transactional email + visitor confirmation.
# RESEND_FROM MUST use a domain verified in your Resend account — gmail.com
# cannot be verified, so set this to e.g. "NeuroDevLab <notify@yourdomain>".
# Owner notifications go to NEXT_PUBLIC_CONTACT_EMAIL regardless; Telegram is
# the primary delivery channel, so an unset/invalid RESEND_FROM never drops a lead.
RESEND_API_KEY=
RESEND_FROM=NeuroDevLab <neurodevlab.ai@gmail.com>

# ── Live AI demo (SERVER-ONLY secret) ────────────────────────
# Anthropic API key for the /api/demo route. NEVER expose to the browser —
# do NOT prefix with NEXT_PUBLIC_. With no key set, the demo degrades
# gracefully (it invites the visitor to send a brief instead of erroring).
ANTHROPIC_API_KEY=
# Optional caps (sane defaults baked into the code — LOI2-style bounds).
# IMPORTANT: the numeric vars MUST be plain integers. The route clamps them
# (DEMO_MAX_TOKENS -> [64,1024], DEMO_MAX_PER_HOUR -> [3,1000]) and ignores any
# non-integer value, so a stray space/quote/comment can no longer break the API
# call — but keep them clean. ANTHROPIC_MODEL must be a valid model id or empty.
ANTHROPIC_MODEL=claude-sonnet-4-6
DEMO_MAX_TOKENS=400
DEMO_MAX_PER_HOUR=10
